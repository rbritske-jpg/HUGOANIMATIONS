// 1. Setup variables (with Save/Load feature)
let monstersCaught = localStorage.getItem('pokemonScore') ? parseInt(localStorage.getItem('pokemonScore')) : 0;
let userPos = { lat: 40.7128, lon: -74.0060 }; // Default starting point

// 2. Load score on startup
window.onload = function() {
    document.getElementById('score-number').innerText = monstersCaught;
    updateRankDisplay();
    startGps(); 
};

// 3. KEYBOARD CONTROLS (For Chromebook users)
window.addEventListener('keydown', function(e) {
    const moveStep = 0.0001; // How far you move per click
    if (e.key === "ArrowUp") userPos.lat += moveStep;
    if (e.key === "ArrowDown") userPos.lat -= moveStep;
    if (e.key === "ArrowLeft") userPos.lon -= moveStep;
    if (e.key === "ArrowRight") userPos.lon += moveStep;
    
    updateMap(); // Redraw your position on the screen
});

// 4. GPS TRACKER (For phones/tablets)
function startGps() {
    if (navigator.geolocation) {
        navigator.geolocation.watchPosition((position) => {
            userPos.lat = position.coords.latitude;
            userPos.lon = position.coords.longitude;
            updateMap();
        });
    }
}

function updateScore() {
    monstersCaught++;
    localStorage.setItem('pokemonScore', monstersCaught);
    document.getElementById('score-number').innerText = monstersCaught;
    updateRankDisplay();
}

function updateRankDisplay() {
    let rankElement = document.getElementById('player-rank');
    if (monstersCaught >= 15) { rankElement.innerText = "Master Trainer"; rankElement.style.color = "#00ffff"; }
    else if (monstersCaught >= 5) { rankElement.innerText = "Pro Adventurer"; rankElement.style.color = "#ffd700"; }
}
